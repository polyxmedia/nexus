# ============================================================================
# NEXUS Intelligence Platform - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked REQUIRED must be set for the platform to function.
# Variables marked OPTIONAL can be omitted; the related feature will be disabled.
# ============================================================================

# ----------------------------------------------------------------------------
# CORE PLATFORM (REQUIRED - platform won't start without these)
# ----------------------------------------------------------------------------

# PostgreSQL connection string (local via Herd, production via Neon)
DATABASE_URL=

# NextAuth session encryption secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Full URL where the app is hosted (e.g. http://localhost:3000)
NEXTAUTH_URL=

# Anthropic Claude API key for AI analysis, chat, and predictions
ANTHROPIC_API_KEY=

# Voyage AI API key for generating embeddings (knowledge bank)
VOYAGE_API_KEY=

# Stripe secret key for server-side payment operations
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for verifying webhook payloads
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key for client-side checkout (must use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# 32-byte hex key for encrypting stored API keys in settings (generate with: openssl rand -hex 32)
SETTINGS_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# MARKET DATA (REQUIRED for market/trading features)
# ----------------------------------------------------------------------------

# Alpha Vantage API key for stock and crypto market data
ALPHA_VANTAGE_API_KEY=

# Alpha Vantage API key alias (some modules reference this name)
ALPHA_VANTAGE_KEY=

# Alpha Vantage rate limit in requests per minute (default: 5 for free tier)
ALPHA_VANTAGE_RPM=

# FRED API key for Federal Reserve economic data (GDP, CPI, rates, etc.)
FRED_API_KEY=

# ----------------------------------------------------------------------------
# TRADING INTEGRATIONS (REQUIRED for specific broker features)
# ----------------------------------------------------------------------------

# Trading 212 API key for stock/ETF trading
TRADING212_API_KEY=

# Trading 212 API secret
TRADING212_SECRET=

# Trading 212 environment: "demo" or "live"
TRADING212_ENVIRONMENT=

# General trading environment flag
TRADING_ENVIRONMENT=

# Coinbase API key for crypto trading
COINBASE_API_KEY=

# Coinbase API secret
COINBASE_API_SECRET=

# Coinbase OAuth client ID for OAuth flow
COINBASE_OAUTH_CLIENT_ID=

# Coinbase OAuth client secret
COINBASE_OAUTH_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# NOTIFICATIONS (REQUIRED for alerting features)
# ----------------------------------------------------------------------------

# Telegram bot token for sending alerts
TELEGRAM_BOT_TOKEN=

# Telegram webhook secret for verifying incoming updates
TELEGRAM_WEBHOOK_SECRET=

# Resend API key for transactional emails
RESEND_API_KEY=

# Sender email address for outgoing emails
EMAIL_FROM=

# Twilio account SID for SMS alerts
TWILIO_ACCOUNT_SID=

# Twilio auth token
TWILIO_AUTH_TOKEN=

# Twilio phone number to send SMS from (e.g. +1234567890)
TWILIO_FROM_NUMBER=

# ----------------------------------------------------------------------------
# EXTERNAL AI & DATA (REQUIRED for specific features)
# ----------------------------------------------------------------------------

# OpenAI API key, used for audio transcription via Whisper
OPENAI_API_KEY=

# NewsData.io API key for news feed ingestion
NEWSDATA_API_KEY=

# ----------------------------------------------------------------------------
# BROKER INTEGRATIONS (OPTIONAL - not yet fully live)
# ----------------------------------------------------------------------------

# Interactive Brokers gateway URL (e.g. https://localhost:5000)
IBKR_GATEWAY_URL=

# Interactive Brokers account ID
IBKR_ACCOUNT_ID=

# Alpaca trading OAuth client ID
ALPACA_OAUTH_CLIENT_ID=

# Alpaca trading OAuth client secret
ALPACA_OAUTH_CLIENT_SECRET=

# IG broker API key
IG_API_KEY=

# IG broker username
IG_USERNAME=

# IG broker password
IG_PASSWORD=

# IG broker account ID
IG_ACCOUNT_ID=

# IG broker environment: "demo" or "live"
IG_ENVIRONMENT=

# IG OAuth client ID
IG_OAUTH_CLIENT_ID=

# IG OAuth client secret
IG_OAUTH_CLIENT_SECRET=

# Kalshi prediction markets API key ID
KALSHI_API_KEY_ID=

# Kalshi environment: "demo" or "live"
KALSHI_ENVIRONMENT=

# Kalshi private key for API authentication
KALSHI_PRIVATE_KEY=

# Polymarket private key for prediction market trading
POLYMARKET_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# INFRASTRUCTURE
# ----------------------------------------------------------------------------

# Secret for authenticating cron job requests
CRON_SECRET=

# Enable or disable AI in the scheduler: "true" or "false"
SCHEDULER_AI_ENABLED=

# Node environment: "development", "production", or "test"
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Public-facing app URL (used in client-side code)
NEXT_PUBLIC_APP_URL=

# Base URL for the app
NEXT_PUBLIC_BASE_URL=

# Site URL used in emails and external links
NEXT_PUBLIC_SITE_URL=

# Automatically set by Vercel during deployment (do not set manually)
# VERCEL_URL=

# Upstash Redis REST URL (REQUIRED for production rate limiting on Vercel)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token (REQUIRED for production rate limiting on Vercel)
UPSTASH_REDIS_REST_TOKEN=
